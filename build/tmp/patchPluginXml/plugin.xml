<idea-plugin>
  <idea-version since-build="243" />
  <version>1.0.0</version>
  <id>com.coding9.claude-code-sessions</id>
  <name>Claude Code Sessions</name>
  <vendor email="info@coding9.de" url="https://coding9.de">coding9</vendor>
  <description><![CDATA[Monitor and manage all running Claude Code CLI sessions directly from your JetBrains IDE.<br>
        <ul>
            <li>See all active Claude sessions across all projects</li>
            <li>Status indicators: Running, Waiting for Input, Waiting for Accept, Finished</li>
            <li>Click to open the project or focus the terminal</li>
            <li>Desktop notifications when a session needs your attention</li>
        </ul>]]></description>
  <depends>com.intellij.modules.platform</depends>
  <extensions defaultExtensionNs="com.intellij">
    <!-- Application-level service that monitors all Claude sessions -->
    <applicationService serviceImplementation="com.coding9.claudecode.services.ClaudeSessionMonitorService" />
    <!-- Auto-start the monitor when the IDE is ready -->
    <applicationListener implementation="com.coding9.claudecode.ClaudeCodeAppLifecycle" topic="com.intellij.ide.AppLifecycleListener" />
    <!-- Tool Window: shows the session list -->
    <toolWindow id="Claude Sessions" anchor="bottom" factoryClass="com.coding9.claudecode.ui.ClaudeToolWindowFactory" icon="/icons/claude_13.svg" canCloseContents="false" />
    <!-- Notifications group -->
    <notificationGroup id="Claude Code Sessions" displayType="BALLOON" isLogByDefault="true" />
  </extensions>
  <actions>
    <group id="ClaudeCode.ToolbarActions" text="Claude Code" popup="false">
      <action id="ClaudeCode.Refresh" class="com.coding9.claudecode.actions.RefreshAction" text="Refresh Sessions" description="Refresh the list of Claude Code sessions" icon="AllIcons.Actions.Refresh" />
      <separator />
      <action id="ClaudeCode.StartSession" class="com.coding9.claudecode.actions.StartSessionAction" text="Start Claude in Current Project" description="Start a new Claude Code session in the current project directory" icon="AllIcons.Actions.Execute" />
    </group>
  </actions>
</idea-plugin>
